# ============================================================
# Environment Configuration Template
# Copy this file to .env and fill in the values before starting
# the server. Variables marked [required] must be set; the server
# will exit with an error if any are missing or empty.
# Variables marked [optional] have sensible defaults or are only
# needed for specific features.
# ============================================================

# [optional] Runtime environment. Controls security defaults and
# log verbosity. Set to "production" on live servers.
# Defaults to "development" if not set.
NODE_ENV=development

# [required] HTTP port the server listens on.
NODE_PORT=1337

# [required] MongoDB connection string. Must include retryWrites=true
# so write operations are automatically retried on transient failures,
# and connectTimeoutMS=10000 so the driver times out after 10 seconds
# instead of hanging indefinitely.
PARSE_SERVER_DATABASE_URI='mongodb://localhost:27017/parseServer?retryWrites=true&w=majority&connectTimeoutMS=10000'

# [required] Publicly reachable URL of the Parse API. Used by Parse
# Server to generate file URLs and by the dashboard to connect.
PARSE_SERVER_URL="http://localhost:1337/parse"

# [required] Unique identifier for this Parse application.
# Must match the app ID used by all clients.
PARSE_SERVER_APPLICATION_ID="myAppId"

# [required] Parse master key. Grants full access to all data —
# never log this value and never expose it to clients.
# Replace with a strong random string before deploying.
# The server will refuse to start in production if this is still
# set to the placeholder value below.
PARSE_SERVER_MASTER_KEY="your-master-key-here"

# [required] Parse client key. Sent by mobile/web clients to
# authenticate API requests.
PARSE_SERVER_CLIENT_KEY="myClientKey"

# [required] Parse JavaScript key. Used by the JavaScript SDK.
PARSE_SERVER_JAVASCRIPT_KEY="myJavascriptKey"

# [required] Parse file key. Used to sign and verify file uploads.
PARSE_SERVER_FILE_KEY="myFileKey"

# [optional] Human-readable name for this application. Displayed
# in the Parse Dashboard header.
PARSE_SERVER_APP_NAME="Sample App"

# [optional] Dashboard login username.
PARSE_SERVER_USER="myUser"

# [optional] Dashboard login password. Never log this value.
PARSE_SERVER_PASSWORD="myPassword"

# [optional] Path to the cloud code entry point loaded by Parse Server
# at startup. Leave commented out if you are not using cloud code.
# PARSE_SERVER_CLOUD="./cloud/main.js"

# [optional] Comma-separated list of origins allowed to make
# cross-origin requests to the API. Leave empty to disable CORS.
# Example: CORS_WHITELIST="https://app.example.com,https://admin.example.com"
CORS_WHITELIST=""
