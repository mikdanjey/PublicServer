  "devDependencies": {
    "eslint-plugin-prettier": "^5.5.5",
    "fast-check": "^4.6.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "prettier-plugin-import-sort": "^0.0.7"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown",
    "*.js": "eslint --cache --fix"
